{
    "$schema": "https://www.schemastore.org/package.json",
    "name": "eslint-plugin-yamllint",
    "version": "0.1.0",
    "private": false,
    "description": "ESLint plugin that runs yamllint-js through ESLint and adds Yamllint config-authoring rules.",
    "keywords": [
        "eslint",
        "eslint-plugin",
        "eslintplugin",
        "yaml",
        "yamllint",
        "typescript"
    ],
    "homepage": "https://github.com/Nick2bad4u/eslint-plugin-yamllint",
    "bugs": {
        "url": "https://github.com/Nick2bad4u/eslint-plugin-yamllint/issues",
        "email": "20943337+Nick2bad4u@users.noreply.github.com"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Nick2bad4u/eslint-plugin-yamllint.git"
    },
    "license": "MIT",
    "author": "Nick2bad4u <20943337+Nick2bad4u@users.noreply.github.com> (https://github.com/Nick2bad4u)",
    "contributors": [
        {
            "name": "Nick2bad4u",
            "email": "20943337+Nick2bad4u@users.noreply.github.com",
            "url": "https://github.com/Nick2bad4u"
        }
    ],
    "sideEffects": false,
    "type": "module",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/plugin.d.ts",
                "default": "./dist/plugin.js"
            },
            "require": {
                "types": "./dist/plugin.d.cts",
                "default": "./dist/plugin.cjs"
            },
            "default": "./dist/plugin.js"
        },
        "./package.json": "./package.json"
    },
    "main": "./dist/plugin.cjs",
    "types": "./dist/plugin.d.cts",
    "files": [
        "dist",
        "docs/rules/**",
        "CHANGELOG.md"
    ],
    "workspaces": [
        "docs/docusaurus"
    ],
    "scripts": {
        "build": "tsc -p tsconfig.build.json && npm run build:types:cjs && npm run build:cjs",
        "build:cjs": "node -e \"require('node:fs').writeFileSync('dist/plugin.cjs','module.exports = require(\\\"./plugin.js\\\").default;\\n')\"",
        "build:clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
        "build:eslint-inspector": "npx -y @eslint/config-inspector@latest build --outDir \"docs/docusaurus/static/eslint-inspector\" --base \"/eslint-plugin-yamllint/eslint-inspector/\"",
        "build:types:cjs": "node -e \"require('node:fs').writeFileSync('dist/plugin.d.cts','import type plugin from \\\"./plugin.js\\\";\\nexport = plugin;\\n')\"",
        "changelog:generate": "git-cliff --config cliff.toml --output CHANGELOG.md",
        "changelog:preview": "git-cliff --config cliff.toml --unreleased",
        "changelog:release-notes": "git-cliff --config cliff.toml --current --strip all",
        "clean:cache": "node scripts/clean-paths.mjs dist coverage cache .cache .vite .turbo",
        "clean:docs": "node scripts/clean-paths.mjs docs/docusaurus/.docusaurus docs/docusaurus/build docs/docusaurus/site-docs/developer/api docs/docusaurus/static/eslint-inspector",
        "coverage": "vitest run --coverage",
        "docs:api": "npm run --workspace docs/docusaurus docs:api",
        "docs:build": "npm run --workspace docs/docusaurus build",
        "docs:check-links": "npm run docs:api && node ./scripts/check-doc-links.mjs",
        "docs:start": "npm run --workspace docs/docusaurus start",
        "docs:typecheck": "npm run --workspace docs/docusaurus typecheck",
        "lint": "cross-env NODE_OPTIONS=--max_old_space_size=16384 eslint --cache --cache-strategy content --cache-location .cache/.eslintcache",
        "lint:actions": "node scripts/lint-actionlint.mjs",
        "lint:all": "npm run lint && npm run lint:prettier && npm run lint:package && npm run lint:actions",
        "lint:compat:eslint9": "node scripts/eslint9-compat-smoke.mjs",
        "lint:node-version-files": "node scripts/sync-node-version-files.mjs --check",
        "lint:package": "npm run lint:node-version-files && npm run lint:package-sort && npm run lint:packagelintrc",
        "lint:package-check": "publint && attw --pack .",
        "lint:package-sort": "sort-package-json \"./package.json\" \"./docs/docusaurus/package.json\"",
        "lint:packagelintrc": "npmPkgJsonLint . --config .npmpackagejsonlintrc.json",
        "lint:prettier": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --check",
        "lint:prettier:fix": "prettier . --log-level warn --cache --cache-location=.cache/.prettier-cache --cache-strategy=content --write",
        "prepublishOnly": "npm run release:check",
        "release:check": "npm run release:verify",
        "release:verify": "npm run build && npm run docs:api && npm run typecheck && npm run test && npm run sync:readme-rules-table && npm run sync:presets-rules-matrix && npm run docs:check-links && npm run docs:build && npm run lint:package-check && npm pack --dry-run",
        "sync:node-version-files": "node scripts/sync-node-version-files.mjs",
        "sync:peer-eslint-range": "node scripts/sync-peer-eslint-range.mjs",
        "sync:presets-rules-matrix": "node scripts/sync-presets-rules-matrix.mjs",
        "sync:presets-rules-matrix:write": "node scripts/sync-presets-rules-matrix.mjs --write",
        "sync:readme-rules-table": "node scripts/sync-readme-rules-table.mjs",
        "sync:readme-rules-table:write": "node scripts/sync-readme-rules-table.mjs --write",
        "pretest": "npm run build",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage --reporter=default",
        "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.build.json --noEmit && tsc -p tsconfig.eslint.json --noEmit && tsc -p tsconfig.js.json --noEmit && npm run --workspace docs/docusaurus typecheck",
        "update-actions": "npx actions-up --yes --style sha",
        "update-deps": "npx ncu -i --install never && npm run sync:peer-eslint-range && npm install --force"
    },
    "overrides": {
        "jsonc-eslint-parser": "$jsonc-eslint-parser"
    },
    "dependencies": {
        "@typescript-eslint/parser": "^8.62.0",
        "@typescript-eslint/utils": "^8.62.0",
        "ts-extras": "^1.0.0",
        "type-fest": "^5.7.0",
        "yaml-eslint-parser": "^2.0.0",
        "yamllint-js": "^0.2.4"
    },
    "devDependencies": {
        "@arethetypeswrong/cli": "^0.18.4",
        "@eslint/config-inspector": "^3.0.4",
        "@microsoft/tsdoc-config": "^0.18.1",
        "@types/node": "^26.0.0",
        "@typescript-eslint/rule-tester": "^8.62.0",
        "@vitest/coverage-v8": "^4.1.9",
        "@vitest/ui": "^4.1.9",
        "actionlint": "^2.0.6",
        "all-contributors-cli": "^6.26.1",
        "cross-env": "^10.1.0",
        "eslint": "^10.5.0",
        "eslint-config-nick2bad4u": "^3.0.0",
        "eslint-formatter-unix": "^9.0.1",
        "fast-check": "^4.8.0",
        "git-cliff": "^2.13.1",
        "gitleaks-config-nick2bad4u": "^1.0.2",
        "knip": "^6.20.0",
        "madge": "^8.0.0",
        "npm-check-updates": "^22.2.7",
        "npm-package-json-lint": "^10.4.1",
        "npm-package-json-lint-config-nick2bad4u": "^1.0.3",
        "picocolors": "^1.1.1",
        "prettier": "^3.8.4",
        "prettier-config-nick2bad4u": "^1.0.17",
        "publint": "^0.3.21",
        "sort-package-json": "^4.0.0",
        "tsdoc-config-nick2bad4u": "^1.0.5",
        "typedoc": "^0.28.19",
        "typedoc-config-nick2bad4u": "^2.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.0",
        "vite": "^8.1.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.9"
    },
    "peerDependencies": {
        "eslint": "^9.0.0 || ^10.0.0",
        "typescript": "^5.0.0 || ^6.0.0"
    },
    "packageManager": "npm@11.17.0",
    "engines": {
        "node": ">=22.0.0"
    },
    "devEngines": {
        "runtime": {
            "name": "node",
            "version": ">=22.0.0",
            "onFail": "error"
        },
        "packageManager": {
            "name": "npm",
            "version": ">=11.0.0",
            "onFail": "error"
        }
    },
    "publishConfig": {
        "provenance": true,
        "registry": "https://registry.npmjs.org/"
    },
    "readme": "README.md"
}
